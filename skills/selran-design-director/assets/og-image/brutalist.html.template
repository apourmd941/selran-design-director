<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>{{og.title}} — OG image</title>
<style>
  @page { size: 1200px 630px; margin: 0; }
  html, body { margin: 0; padding: 0; width: 1200px; height: 630px; overflow: hidden; }
  body {
    background: {{color.bg_primary}};
    color: {{color.fg_primary}};
    font-family: "{{type.body}}", "Courier New", monospace;
    -webkit-font-smoothing: antialiased;
    padding: 48px;
    box-sizing: border-box;
    border: 8px solid {{color.fg_primary}};
  }
  .frame {
    width: 100%; height: 100%;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 32px;
  }
  .top {
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 2px solid {{color.fg_primary}};
    padding-bottom: 24px;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: {{type.tracking.caps}}em;
    font-weight: 700;
  }
  .logo { color: {{color.accent}}; }
  h1 {
    font-family: "{{type.display}}", "Courier New", monospace;
    font-size: 108px;
    font-weight: 700;
    line-height: 1;
    color: {{color.fg_primary}};
    margin: 0;
    text-transform: uppercase;
    word-break: break-word;
  }
  .subtitle {
    font-size: 22px;
    line-height: 1.4;
    color: {{color.fg_secondary}};
    max-width: 780px;
    margin-top: 24px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .bottom {
    display: flex; justify-content: space-between; align-items: baseline;
    border-top: 2px solid {{color.fg_primary}};
    padding-top: 20px;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: {{type.tracking.caps}}em;
  }
  .bytes { background: {{color.fg_primary}}; color: {{color.bg_primary}}; padding: 4px 10px; }
</style>
</head>
<body>
  <div class="frame">
    <div class="top">
      <span class="logo">{{og.logo}}</span>
      <span>1200 × 630</span>
    </div>
    <div>
      <h1>{{og.title}}</h1>
      <div class="subtitle">{{og.subtitle}}</div>
    </div>
    <div class="bottom">
      <span class="bytes">v{{meta.version}}</span>
      <span>— EOF</span>
    </div>
  </div>
</body>
</html>
